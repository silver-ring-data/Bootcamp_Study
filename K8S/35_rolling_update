# 아래는 리눅스에서 EKS 생성하는 명령어.
# 설명

# 파일 생성할때는 cat이 편함
cat <<EOF > eks-freetier-setup.yaml
apiVersion: eksctl.io/v1alpha5
kind: ClusterConfig # 클러스터 만드는 설정

metadata: #
  name: free-vpc-cluster
  region: sa-east-1
  version: "1.34" #환경마다 쿠버네티스 지원하는 버전이 다르기 때문에 생각보다 중요함

vpc:
  clusterEndpoints:
    publicAccess: true
    privateAccess: true # 실무에서는 private으로 만드는 것을 권장함. 퍼플릭/프라이빗 통신 방식이 다름
  nat: # private을 만들었기 때문에 gateway를 필수로 만들어줘야함/ Private는 2개로 보통 만들어서 1개는 통신이 안되는 db로 만듦
    gateway: Single # 비용 절감을 위해 NAT 게이트웨이를 1개만 생성 (중요!)

managedNodeGroups: # 도커 노드 그룹
  - name: standard-nodes #
    # --- 인스턴스 타입 선택 가이드 --- (프리티어에서는 4가지만)
    # 1. t3.micro : 프리티어 대상 (단, K8s 시스템 Pod 실행 시 리소스가 매우 부족할 수 있음)
    # 2. t3.small : 가성비 추천 (시스템 안정성 확보)
    # 3. c7i-flex.large (2cpu/4gb) : 연산 위주
    # 4. m7i-flex.large (2cpu/8gb) : 메모리 여유
    instanceType: m7i-flex.large
    
    minSize: 1
    maxSize: 10
    desiredCapacity: 3 
    privateNetworking: true
    iam:
      withAddonPolicies: # iam 권한 관련?
        imageBuilder: true
        autoScaler: true
        cloudWatch: true

# 필수 애드온만 설치
addons:
  - name: vpc-cni
  - name: coredns
  - name: kube-proxy # 로드 밸런서 관련
# 나중에 여유되면 storage 등등을 깔아주면 됨
EOF

# 클러스터 생성 시작

eksctl create cluster -f eks-freetier-setup.yaml


